PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/portfolio
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

ADMIN_USERNAME=admin_username
ADMIN_EMAIL=admin_email
ADMIN_PASSWORD=admin_password
ADMIN_NAME=admin_name

# Comma-separated frontend origins (local + production). Vercel *.vercel.app is also allowed automatically.
CLIENT_URL=http://localhost:5173,http://localhost:5174,https://your-portfolio.vercel.app,https://your-admin.vercel.app

# AI — portfolio chatbot + admin skill suggestions (set one provider)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Portfolio profile (optional — or set in Admin → Profile)
PROFILE_LINKEDIN_URL=profile_url
# Paste LinkedIn photo URL: open LinkedIn → your photo → Copy image address
PROFILE_IMAGE_URL=
